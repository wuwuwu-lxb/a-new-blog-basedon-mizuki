{
	"name": "小晤",
	"type": "module",
	"version": "8.3",
	"scripts": {
		"dev": "astro dev",
		"dev:all": "node scripts/dev-all.js",
		"dev:api": "pnpm --filter ./api dev",
		"init-db": "node scripts/init-db.js",
		"test-api": "node scripts/test-api.js",
		"sync-content": "node scripts/sync-content.js",
		"init-content": "node scripts/init-content-repo.js",
		"vec-init": "tsx scripts/vec-init.ts",
		"predev": "node scripts/sync-content.js || true",
		"prebuild": "node scripts/sync-content.js || true",
		"check": "astro check",
		"update-anime": "node scripts/update-anime.mjs",
		"update-bangumi": "node scripts/update-bangumi.mjs",
		"update-bilibili": "node scripts/update-bilibili.mjs",
		"build": "node scripts/update-anime.mjs && astro build && (pagefind --site dist/client --output-path public/pagefind || echo 'Pagefind skipped (SSR mode)') && node scripts/compress-fonts.js",
		"submit": "node scripts/indexnow-submit.js",
		"preview": "astro preview",
		"astro": "astro",
		"type-check": "tsc --noEmit --isolatedDeclarations",
		"new-post": "node scripts/new-post.js",
		"format": "prettier --write ./src",
		"lint": "eslint ./src --fix",
		"preinstall": "npx only-allow pnpm",
		"compress-fonts": "node scripts/compress-fonts.js",
		"test-font-compression": "node scripts/test-font-compression.js"
	},
	"dependencies": {
		"@astrojs/check": "^0.9.7",
		"@astrojs/node": "^10.0.2",
		"@astrojs/rss": "^4.0.17",
		"@astrojs/sitemap": "^3.7.1",
		"@astrojs/svelte": "8.0.0",
		"@expressive-code/core": "^0.41.7",
		"@expressive-code/plugin-collapsible-sections": "^0.41.7",
		"@expressive-code/plugin-line-numbers": "^0.41.7",
		"@fancyapps/ui": "^6.1.12",
		"@fontsource-variable/jetbrains-mono": "^5.2.8",
		"@fontsource/roboto": "^5.2.10",
		"@iconify-json/fa7-brands": "^1.2.2",
		"@iconify-json/fa7-regular": "^1.2.3",
		"@iconify-json/fa7-solid": "^1.2.4",
		"@iconify-json/material-symbols": "^1.2.59",
		"@iconify-json/simple-icons": "^1.2.71",
		"@iconify/svelte": "^5.2.1",
		"@swup/astro": "^1.8.0",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.1",
		"astro": "6.0.4",
		"astro-expressive-code": "^0.41.7",
		"astro-icon": "^1.1.5",
		"axios": "^1.13.6",
		"bcryptjs": "^3.0.3",
		"better-sqlite3": "^12.8.0",
		"crypto-js": "^4.2.0",
		"dayjs": "^1.11.19",
		"dotenv": "^17.3.1",
		"glob": "^13.0.6",
		"gray-matter": "^4.0.3",
		"hastscript": "^9.0.1",
		"jsonwebtoken": "^9.0.3",
		"katex": "^0.16.33",
		"markdown-it": "^14.1.1",
		"marked": "^16.4.2",
		"node-html-parser": "^7.0.2",
		"oddmisc": "^1.1.5",
		"overlayscrollbars": "^2.14.0",
		"pagefind": "^1.4.0",
		"photoswipe": "^5.4.4",
		"qrcode": "^1.5.4",
		"reading-time": "^1.5.0",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-components": "^0.3.0",
		"rehype-external-links": "^3.0.0",
		"rehype-katex": "^7.0.1",
		"rehype-slug": "^6.0.0",
		"remark-directive": "^3.0.1",
		"remark-directive-rehype": "^0.4.2",
		"remark-math": "^6.0.0",
		"remark-sectionize": "^2.1.0",
		"sanitize-html": "^2.17.1",
		"satori": "^0.19.2",
		"sharp": "^0.34.5",
		"sqlite-vec": "^0.1.7",
		"stylus": "^0.64.0",
		"svelte": "^5.53.6",
		"tailwindcss": "^4.2.1",
		"typescript": "^5.9.3",
		"unist-util-visit": "^5.1.0"
	},
	"devDependencies": {
		"@astrojs/ts-plugin": "^1.10.7",
		"@iconify-json/mdi": "^1.2.3",
		"@prisma/client": "^6.19.2",
		"@rollup/plugin-yaml": "^4.1.2",
		"@types/bcryptjs": "^3.0.0",
		"@types/better-sqlite3": "^7.6.13",
		"@types/hast": "^3.0.4",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/markdown-it": "^14.1.2",
		"@types/mdast": "^4.0.4",
		"@types/qrcode": "^1.5.6",
		"@types/sanitize-html": "^2.16.0",
		"concurrently": "^9.1.2",
		"fontmin": "^1.1.1",
		"postcss-import": "^16.1.1",
		"postcss-nesting": "^13.0.2",
		"prettier": "^3.8.1",
		"prettier-plugin-astro": "^0.14.1",
		"prettier-plugin-svelte": "^3.5.0",
		"prisma": "^6.19.2",
		"tsx": "^4.21.0"
	},
	"packageManager": "pnpm@10.22.0",
	"pnpm": {
		"overrides": {
			"@emmetio/css-parser": "https://codeload.github.com/ramya-rao-a/css-parser/tar.gz/370c480ac103bd17c7bcfb34bf5d577dc40d3660"
		},
		"ignoredBuiltDependencies": [
			"better-sqlite3"
		]
	}
}
