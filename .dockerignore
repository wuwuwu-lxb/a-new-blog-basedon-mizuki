# Docker 构建忽略文件
.git
.gitignore
.github
.gitattributes

# 开发配置文件
.env
.env.local
.env.*.local
.env.test

# 构建产物（Dockerfile 会重新构建）
dist
.api/.next
public/pagefind

# 依赖目录（Docker 会重新安装）
node_modules
api/node_modules

# 数据文件（使用 Docker 卷）
prisma/*.db
prisma/*.db-journal
public/uploads

# 日志文件
logs
*.log
npm-debug.log*
pnpm-debug.log*

# 测试文件
coverage
*.test.ts
*.spec.ts
__tests__
tests

# IDE 配置
.idea
.vscode
*.swp
*.swo
*~
.DS_Store

# 部署文件（不需要打包）
deploy
ecosystem.config.js
pm2.json

# 脚本（部分不需要）
scripts/deploy.sh
scripts/dev-all.js

# 临时文件
tmp
temp
.cache
.turbo
