---
import { commentConfig } from "@/config";
import CommentsPanel from "./CommentsPanel.svelte";

interface Props {
    article?: {
        id: number;
        slug: string;
        comment: boolean;
        title: string;
    };
    post?: {
        id: string;
        data: {
            comment?: boolean;
        };
    };
}

// 支持数据库文章或 Content Collection 文章
let commentSlug: string;
let commentEnabled: boolean;

if (Astro.props.article) {
    // 数据库文章
    commentSlug = Astro.props.article.slug;
    commentEnabled = Astro.props.article.comment ?? true;
} else if (Astro.props.post) {
    // Content Collection 文章
    const { id, data } = Astro.props.post;
    commentSlug = id.replace(/\.(md|mdx|markdown)$/i, "");
    commentEnabled = data.comment ?? true;
} else {
    commentEnabled = false;
    commentSlug = "";
}

let commentService = "";
if (commentConfig?.enable && commentConfig?.twikoo) {
    commentService = "twikoo";
}
---

{commentConfig?.enable && commentEnabled && (
    <div class="card-base p-6 mb-4">
        <CommentsPanel client:only="svelte" commentSlug={commentSlug} />
    </div>
)}
