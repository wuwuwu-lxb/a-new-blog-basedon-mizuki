---
import Layout from '../../layouts/Layout.astro';
---

<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>管理后台 - 小唔</title>
	</head>
	<body>
		<Layout>
			<div class="admin-container">
				<h1>管理后台</h1>
				<p class="welcome-text">欢迎回来，管理员</p>

				<div class="admin-grid">
					<div class="admin-card">
						<h2>📝 文章管理</h2>
						<p>管理所有文章内容，支持 Markdown</p>
						<a href="/admin/articles" class="admin-btn">进入</a>
					</div>

					<div class="admin-card">
						<h2>💬 Chat 设置</h2>
						<p>配置 AI 聊天的系统提示词和 API 端点</p>
						<a href="/admin/chat" class="admin-btn">进入</a>
					</div>

					<div class="admin-card">
						<h2>🧠 RAG 向量搜索</h2>
						<p>基于向量相似度的文章语义搜索</p>
						<a href="/admin/vector-search" class="admin-btn">进入</a>
					</div>

					<div class="admin-card">
						<h2>🔧 开发中</h2>
						<p>更多管理功能敬请期待</p>
						<span class="admin-btn disabled">敬请期待</span>
					</div>
				</div>
			</div>
		</Layout>

		<script>
			// 前端路由守卫：检查登录状态
			(function() {
				const token = localStorage.getItem('admin_token');
				if (!token) {
					// 未登录，重定向到登录页
					window.location.href = '/login';
					return;
				}

				// 可选：验证 token 有效性
				fetch('/api/auth/verify', {
					headers: { 'Authorization': 'Bearer ' + token }
				})
				.then(res => {
					if (!res.ok) {
						// Token 无效，清除并重定向
						localStorage.removeItem('admin_token');
						window.location.href = '/login';
					}
				})
				.catch(() => {
					// 网络错误，不处理，允许访问
				});
			})();
		</script>
	</body>
</html>

<style>
	.admin-container {
		min-height: calc(100vh - 200px);
		padding: 2rem;
		max-width: 1200px;
		margin: 0 auto;
	}

	h1 {
		font-size: 2rem;
		font-weight: bold;
		margin-bottom: 0.5rem;
		color: var(--text-primary);
	}

	.welcome-text {
		color: var(--text-secondary);
		margin-bottom: 2rem;
	}

	.admin-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		gap: 1.5rem;
	}

	.admin-card {
		background: var(--card-bg);
		border-radius: 1rem;
		padding: 1.5rem;
		transition: transform 0.2s, box-shadow 0.2s;
	}

	.admin-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
	}

	.admin-card h2 {
		font-size: 1.25rem;
		font-weight: 600;
		margin-bottom: 0.5rem;
		color: var(--text-primary);
	}

	.admin-card p {
		color: var(--text-secondary);
		font-size: 0.875rem;
		margin-bottom: 1rem;
	}

	.admin-btn {
		display: inline-block;
		background: var(--primary);
		color: var(--bg);
		padding: 0.5rem 1.5rem;
		border-radius: 0.5rem;
		font-weight: 500;
		font-size: 0.875rem;
		text-decoration: none;
		transition: opacity 0.2s;
	}

	.admin-btn:hover {
		opacity: 0.9;
	}

	.admin-btn.disabled {
		background: #ccc;
		cursor: not-allowed;
		pointer-events: none;
	}
</style>
