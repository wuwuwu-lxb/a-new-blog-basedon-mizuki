---
import Pagination from "../components/control/Pagination.astro";
import PostPage from "../components/PostPage.astro";
import { PAGE_SIZE } from "../constants/constants";
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { getSortedPosts, getSortedPostsListWithUrl } from "../utils/content-utils";

// 使用 prerender = true 生成静态页面供 Pagefind 索引
export const prerender = true;

// 获取所有排序后的文章
const allBlogPosts = await getSortedPosts();
const allBlogPostsList = await getSortedPostsListWithUrl();
const totalPages = Math.ceil(allBlogPosts.length / PAGE_SIZE);

// 生成分页路径
export async function getStaticPaths() {
    const posts = await getSortedPosts();
    const total = Math.ceil(posts.length / PAGE_SIZE);
    const paths: Array<{ params: { page?: string }; props: { currentPage: number } }> = [];
    for (let i = 1; i <= total; i++) {
        paths.push({
            params: { page: i === 1 ? undefined : String(i) },
            props: { currentPage: i },
        });
    }
    return paths;
}

// 获取当前页码
const { page: pageParam } = Astro.params;
const currentPage = pageParam ? parseInt(pageParam, 10) : 1;

const startIndex = (currentPage - 1) * PAGE_SIZE;
const endIndex = startIndex + PAGE_SIZE;
const pageData = allBlogPostsList.slice(startIndex, endIndex);

// 构建分页 URL
const currentUrl = currentPage <= 1 ? '/' : `/${currentPage}`;
const nextUrl = currentPage < totalPages ? `/${currentPage + 1}` : null;
const prevUrl = currentPage > 1 ? `/${currentPage - 1}` : null;

const page = {
    data: pageData,
    currentPage: currentPage,
    lastPage: totalPages,
    url: {
        current: currentUrl,
        next: nextUrl,
        prev: prevUrl
    }
};

const len = page.data.length;
---

<MainGridLayout>
    <PostPage page={page}></PostPage>
    <Pagination class="mx-auto onload-animation" page={page} style={`animation-delay: calc(var(--content-delay) + ${(len)*50}ms)`}></Pagination>
</MainGridLayout>
