---
import Comment from "@components/comment/index.astro";
import License from "@components/misc/License.astro";
import SharePoster from "@components/misc/SharePoster.svelte";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getArticleBySlug } from "@utils/content-utils";
import { getPostUrlBySlug } from "@utils/url-utils";
import { Icon } from "astro-icon/components";
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import { licenseConfig, shareConfig } from "src/config";
import ImageWrapper from "../../components/misc/ImageWrapper.astro";
import PostMetadata from "../../components/PostMeta.astro";
import { profileConfig, siteConfig } from "../../config";
import { formatDateToYYYYMMDD } from "../../utils/date-utils";
import Encryptor from "../../components/Encryptor.astro";
import { prisma } from '@/lib/prisma';

// 使用 SSR 模式
export const prerender = false;

// 从路由参数获取 slug
const { slug } = Astro.params;

if (!slug) {
    return Astro.redirect('/404');
}

// 从数据库获取文章
const article = await getArticleBySlug(slug);

// 如果文章不存在，返回 404
if (!article || (!article.published && import.meta.env.PROD)) {
    return Astro.redirect('/404');
}

// 获取浏览量（从数据库）
const viewsCount = article.views;

// 增加浏览量
await prisma.article.update({
    where: { id: article.id },
    data: { views: article.views + 1 },
});

// 处理封面图片
let posterCoverUrl = article.cover || '';
if (posterCoverUrl && posterCoverUrl.startsWith("http")) {
    try {
        const response = await fetch(posterCoverUrl);
        const arrayBuffer = await response.arrayBuffer();
        const base64 = Buffer.from(arrayBuffer).toString("base64");
        const contentType = response.headers.get("content-type") || "image/jpeg";
        posterCoverUrl = `data:${contentType};base64,${base64}`;
    } catch {
        // 保持原 URL
    }
}

// 处理头像
let posterAvatarUrl = profileConfig.avatar || '';

// 判断是否为加密文章
const isEncrypted = article.encrypted && article.password;

// 获取最后修改时间
dayjs.extend(utc);
const lastModified = dayjs(article.modifiedAt || article.publishedAt || article.createdAt)
    .utc()
    .format("YYYY-MM-DDTHH:mm:ss");

// JSON-LD 结构化数据
const jsonLd = {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: article.title,
    description: article.excerpt || article.title,
    keywords: article.tags.map(t => t.name),
    author: {
        "@type": "Person",
        name: profileConfig.name,
        url: Astro.site,
    },
    datePublished: formatDateToYYYYMMDD(article.publishedAt),
    inLanguage: article.lang
        ? article.lang.replace("_", "-")
        : siteConfig.lang.replace("_", "-"),
};

// 计算字数和阅读时间（中文字符统计，英文按词统计）
const textContent = article.rawContent.replace(/[#*`\[\]]/g, '');
// 提取中文字符数量
const chinesePart = textContent.match(/[\u4e00-\u9fa5]/g) || [];
const chineseCount = chinesePart.length;
// 提取英文字符数量（按空格分词）
const englishPart = textContent.replace(/[\u4e00-\u9fa5]/g, ' ');
const englishWords = englishPart.split(/\s+/).filter(w => w.length > 0).length;
const wordCount = chineseCount + englishWords;
const readingMinutes = Math.max(1, Math.ceil(wordCount / 200));
---

<MainGridLayout
    banner={article.cover}
    title={article.title}
    description={article.excerpt || ''}
    lang={article.lang || undefined}
    setOGTypeArticle={true}
    postSlug={String(article.id)}
>
    <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <!-- 引入右侧边栏布局管理器 -->
    <script>
        import('../../scripts/right-sidebar-layout.js');
    </script>

    <div
        class="flex w-full rounded-(--radius-large) overflow-hidden relative mb-4"
    >
        <div
            id="post-container"
            class:list={[
                "card-base z-10 px-6 md:px-9 pt-6 pb-4 relative w-full ",
                {},
            ]}
        >
            <!-- word count and reading time -->
            <div
                class="flex flex-row text-50 gap-5 mb-3 transition onload-animation"
            >
                <div class="flex flex-row items-center">
                    <div
                        class="transition h-6 w-6 rounded-md bg-(--line-divider) flex items-center justify-center mr-2"
                    >
                        <Icon name="material-symbols:notes-rounded" />
                    </div>
                    <div class="text-sm">
                        {wordCount}
                        {" " + i18n(I18nKey.wordsCount)}
                    </div>
                </div>
                <div class="flex flex-row items-center">
                    <div
                        class="transition h-6 w-6 rounded-md bg-(--line-divider) flex items-center justify-center mr-2"
                    >
                        <Icon
                            name="material-symbols:schedule-outline-rounded"
                        />
                    </div>
                    <div class="text-sm">
                        {readingMinutes}
                        {
                            " " +
                                i18n(
                                    readingMinutes === 1
                                        ? I18nKey.minuteCount
                                        : I18nKey.minutesCount,
                                )
                        }
                    </div>
                </div>
            </div>

            <!-- title -->
            <div class="relative onload-animation">
                <div
                    data-pagefind-body
                    data-pagefind-weight="10"
                    data-pagefind-meta="title"
                    class="transition w-full block font-bold mb-3
                    text-3xl md:text-[2.25rem]/[2.75rem]
                    text-90
                    md:before:w-1 before:h-5 before:rounded-md before:bg-(--primary)
                    before:absolute before:top-3 before:-left-4.5"
                >
                    {article.title}
                </div>
            </div>

            <!-- metadata -->
            <div class="onload-animation">
                <PostMetadata
                    className="mb-5"
                    published={article.publishedAt}
                    updated={article.modifiedAt}
                    tags={article.tags.map(t => t.name)}
                    category={article.categories[0]?.name || undefined}
                    id={String(article.id)}
                    viewsCount={viewsCount}
                />
                {
                    (!article.cover || (article.cover && !siteConfig.showCoverInContent)) && (
                        <div class="mt-4 border-(--line-divider) border-dashed border-b mb-5" />
                    )
                }
            </div>

            <!-- always show cover as long as it has one -->
            {
                article.cover && siteConfig.showCoverInContent && (
                    <>
                        <div class="mt-4" />
                        <ImageWrapper
                            id="post-cover"
                            src={article.cover}
                            class="mb-8 rounded-xl banner-container onload-animation"
                        />
                    </>
                )
            }

            {
                isEncrypted ? (
                    <Encryptor password={article.password || ''}>
                        <div class="mb-6 markdown-content onload-animation" set:html={article.content} />
                    </Encryptor>
                ) : (
                    <div class="mb-6 markdown-content onload-animation" set:html={article.content} />
                )
            }

            {shareConfig.enable && (
                <div id="share-component" class:list={["p-6 bg-(--license-block-bg) rounded-xl mb-6 onload-animation", { "encrypted-hidden": isEncrypted }]}>
                    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
                        <div class="flex items-center gap-3 flex-1">
                            <div class="flex items-center justify-center h-12 w-12 rounded-lg bg-(--enter-btn-bg)">
                                <Icon
                                    name="material-symbols:share"
                                    class="text-3xl text-(--primary)"
                                />
                            </div>
                            <div class="flex flex-col gap-1">
                                <div class="text-[1.0rem] leading-tight text-75">
                                    {i18n(I18nKey.shareOnSocial)}
                                </div>
                                <p class="text-[0.8rem] leading-tight text-75">
                                    {i18n(I18nKey.shareOnSocialDescription)}
                                </p>
                            </div>
                        </div>
                        <div class="flex items-center gap-3">
                            <SharePoster
                                client:load
                                title={article.title}
                                author={article.authorName || profileConfig.name}
                                description={article.excerpt || ""}
                                pubDate={formatDateToYYYYMMDD(article.publishedAt)}
                                coverImage={posterCoverUrl}
                                url={Astro.url.toString()}
                                siteTitle={siteConfig.title}
                                avatar={posterAvatarUrl}
                            />
                        </div>
                    </div>
                </div>
            )}

            {licenseConfig.enable && (
                <div id="license-component" class:list={["encrypted-hidden-wrapper", { "encrypted-hidden": isEncrypted }]}>
                    <License
                        title={article.title}
                        id={String(article.id)}
                        pubDate={article.publishedAt}
                        author={article.authorName}
                        sourceLink={article.sourceLink}
                        licenseName={article.licenseName}
                        licenseUrl={article.licenseUrl}
                        class="mb-6 rounded-xl license-container onload-animation"
                    />
                </div>
            )}
        </div>
    </div>

    <!-- 评论 -->
    <Comment article={article} />

    {siteConfig.showLastModified && (
        <>
            <div
                id="last-modified"
                data-last-modified={lastModified}
                data-prefix={i18n(I18nKey.lastModifiedPrefix)}
                data-year={i18n(I18nKey.year)}
                data-month={i18n(I18nKey.month)}
                data-day={i18n(I18nKey.day)}
                data-hour={i18n(I18nKey.hour)}
                data-minute={i18n(I18nKey.minute)}
                data-second={i18n(I18nKey.second)}
                style="display: none;"
            ></div>

            <div class="card-base p-6 mb-4">
                <script is:inline>
                    function runtime() {
                        const lastModifiedElement = document.getElementById('last-modified');
                        if (!lastModifiedElement) return;

                        const startDate = new Date(lastModifiedElement.dataset.lastModified);
                        const currentDate = new Date();
                        const diff = currentDate - startDate;
                        const seconds = Math.floor(diff / 1000);
                        const days = Math.floor(seconds / 86400);
                        const hours = Math.floor((seconds % 86400) / 3600);
                        const minutes = Math.floor((seconds % 3600) / 60);
                        const secs = seconds % 60;

                        const years = Math.floor(days / 365);
                        const months = Math.floor((days % 365) / 30);
                        const remainingDays = days % 30;

                        const prefix = lastModifiedElement.dataset.prefix;
                        const yearKey = lastModifiedElement.dataset.year;
                        const monthKey = lastModifiedElement.dataset.month;
                        const dayKey = lastModifiedElement.dataset.day;
                        const hourKey = lastModifiedElement.dataset.hour;
                        const minuteKey = lastModifiedElement.dataset.minute;
                        const secondKey = lastModifiedElement.dataset.second;

                        let runtimeString = prefix + ' ';
                        if (years > 0) {
                            runtimeString += `${years} ${yearKey} `;
                        }
                        if (months > 0) {
                            runtimeString += `${months} ${monthKey} `;
                        }
                        if (remainingDays > 0) {
                            runtimeString += `${remainingDays} ${dayKey} `;
                        }
                        runtimeString += `${hours} ${hourKey} `;
                        if (minutes < 10) {
                            runtimeString += `0${minutes} ${minuteKey} `;
                        } else {
                            runtimeString += `${minutes} ${minuteKey} `;
                        }
                        if (secs < 10) {
                            runtimeString += `0${secs} ${secondKey}`;
                        } else {
                            runtimeString += `${secs} ${secondKey}`;
                        }

                        document.getElementById("modifiedtime").innerHTML = runtimeString;
                    }
                    setInterval(runtime, 1000);
                </script>
                <div class="flex items-center gap-3">
                    <div class="flex items-center justify-center h-12 w-12 rounded-lg bg-(--enter-btn-bg)">
                        <Icon
                            name="material-symbols:history-rounded"
                            class="text-3xl text-(--primary)"
                        />
                    </div>
                    <div class="flex flex-col gap-1">
                        <div id="modifiedtime" class="text-[1.0rem] leading-tight text-75"></div>
                        <p class="text-[0.8rem] leading-tight text-75">
                            {i18n(I18nKey.lastModifiedOutdated)}
                        </p>
                    </div>
                </div>
            </div>
        </>
    )}

    <div
        class="flex flex-col md:flex-row justify-between mb-4 gap-4 overflow-hidden w-full"
    >
        <a
            href={article.nextSlug
                ? getPostUrlBySlug(article.nextSlug)
                : "#"}
            class:list={[
                "w-full font-bold overflow-hidden active:scale-95",
                { "pointer-events-none": !article.nextSlug },
            ]}
        >
            {
                article.nextSlug && (
                    <div class="btn-card rounded-2xl w-full h-15 max-w-full px-4 flex items-center justify-start! gap-4">
                        <Icon
                            name="material-symbols:chevron-left-rounded"
                            class="text-[2rem] text-(--primary)"
                        />
                        <div class="overflow-hidden transition text-ellipsis whitespace-nowrap max-w-[calc(100%-3rem)] text-75">
                            {article.nextTitle}
                        </div>
                    </div>
                )
            }
        </a>

        <a
            href={article.prevSlug
                ? getPostUrlBySlug(article.prevSlug)
                : "#"}
            class:list={[
                "w-full font-bold overflow-hidden active:scale-95",
                { "pointer-events-none": !article.prevSlug },
            ]}
        >
            {
                article.prevSlug && (
                    <div class="btn-card rounded-2xl w-full h-15 max-w-full px-4 flex items-center justify-end! gap-4">
                        <div class="overflow-hidden transition text-ellipsis whitespace-nowrap max-w-[calc(100%-3rem)] text-75">
                            {article.prevTitle}
                        </div>
                        <Icon
                            name="material-symbols:chevron-right-rounded"
                            class="text-[2rem] text-(--primary)"
                        />
                    </div>
                )
            }
        </a>
    </div>
</MainGridLayout>
