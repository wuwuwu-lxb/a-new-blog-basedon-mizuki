# 数据库配置
DATABASE_URL="postgresql://username:password@localhost:5432/mizuki_db?schema=public"

# NextAuth 配置
NEXTAUTH_SECRET="your-secret-key-change-this-in-production"
NEXTAUTH_URL="http://localhost:3001"

# JWT 配置
JWT_SECRET="your-jwt-secret-key"

# Chat API 配置 (可选)
# 如需使用聊天功能，请从下面选择一个方案，填入 API Key

# === 方案一：使用 DeepSeek (推荐，性价比高) ===
# 官网：https://platform.deepseek.com/
# OPENAI_API_KEY="sk-your-deepseek-api-key"
# CHAT_MODEL="deepseek-chat"
# CHAT_API_URL="https://api.deepseek.com/v1/chat/completions"

# === 方案二：使用 Moonshot (月之暗面/Kimi) ===
# 官网：https://platform.moonshot.cn/
# OPENAI_API_KEY="sk-your-moonshot-api-key"
# CHAT_MODEL="moonshot-v1-8k"
# CHAT_API_URL="https://api.moonshot.cn/v1/chat/completions"

# === 方案三：使用 SiliconFlow (硅基流动) ===
# 官网：https://cloud.siliconflow.cn/
# OPENAI_API_KEY="sk-your-siliconflow-api-key"
# CHAT_MODEL="deepseek-ai/DeepSeek-V3"
# CHAT_API_URL="https://api.siliconflow.cn/v1/chat/completions"

# === 方案四：使用 OpenAI ===
# OPENAI_API_KEY="sk-your-openai-api-key"
# CHAT_MODEL="gpt-3.5-turbo"
# CHAT_API_URL="https://api.openai.com/v1/chat/completions"

# === 方案五：使用 Azure OpenAI ===
# OPENAI_API_KEY="your-azure-api-key"
# CHAT_MODEL="your-deployment-name"
# CHAT_API_URL="https://your-resource.openai.azure.com/openai/deployments/your-deployment-name/chat/completions?api-version=2024-02-15-preview"

# === 方案六：使用 Ollama (本地部署，免费) ===
# 官网：https://ollama.ai/
# OPENAI_API_KEY="ollama"
# CHAT_MODEL="llama3.1:8b"
# CHAT_API_URL="http://localhost:11434/v1/chat/completions"

# === 方案七：使用通义千问 (阿里云) ===
# 官网：https://dashscope.console.aliyun.com/
# OPENAI_API_KEY="sk-your-dashscope-api-key"
# CHAT_MODEL="qwen-plus"
# CHAT_API_URL="https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions"

# === 方案八：使用智谱 AI (GLM) ===
# 官网：https://open.bigmodel.cn/
# OPENAI_API_KEY="your-zhipu-api-key"
# CHAT_MODEL="glm-4"
# CHAT_API_URL="https://open.bigmodel.cn/api/paas/v4/chat/completions"

# 当前启用的配置 (请从上面选择一个方案，取消注释并删除下面的默认配置)
OPENAI_API_KEY=""
CHAT_MODEL="gpt-3.5-turbo"
CHAT_API_URL="https://api.openai.com/v1/chat/completions"

# 邮件配置 (用于评论通知等)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# 文件上传配置
MAX_UPLOAD_SIZE="10485760"
UPLOAD_DIR="./uploads"
