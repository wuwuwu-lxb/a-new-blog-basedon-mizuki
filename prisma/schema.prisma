// Prisma Schema for Mizuki Blog API
// https://www.prisma.io/docs/concepts/components/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 用户模型
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  password  String   // bcrypt 加密后的密码
  role      Role     @default(USER)
  avatar    String?
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  articles Article[]
  comments Comment[]
  notifications Notification[]
  notificationsFrom Notification[] @relation("NotificationFromUser")

  @@map("users")
}

// 用户角色枚举
enum Role {
  USER
  ADMIN
}

// 文章模型
model Article {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  content     String   // 预渲染的 HTML 内容
  rawContent  String   // 原始 Markdown（编辑时用）
  excerpt     String?
  cover       String?
  published   Boolean  @default(false)
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  publishedAt DateTime?

  authorId   Int
  author     User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  tags       Tag[]
  categories Category[]
  comments   Comment[]
  vectors    ArticleVector[]

  // 扩展字段（对应 Markdown frontmatter）
  draft        Boolean   @default(false)       // draft: z.boolean()
  modifiedAt   DateTime?                     // frontmatter updated date
  lang         String?                       // lang: z.string()
  pinned       Boolean   @default(false)       // pinned: z.boolean()
  comment      Boolean   @default(true)        // comment: z.boolean()
  priority     Int?                          // priority: z.number()
  authorName   String?                        // author: z.string()
  sourceLink   String?                        // sourceLink: z.string()
  licenseName  String?                       // licenseName: z.string()
  licenseUrl   String?                       // licenseUrl: z.string()

  // 加密字段
  encrypted    Boolean   @default(false)       // encrypted: z.boolean()
  password     String?                        // password: z.string()

  // 自定义链接
  permalink    String?                        // permalink: z.string()
  alias        String?                        // alias: z.string()

  // 上一篇/下一篇链接
  prevSlug     String?
  prevTitle    String?
  nextSlug     String?
  nextTitle    String?

  // 序号（用于固定链接）
  numericId    Int?

  @@map("articles")
}

// 文章向量模型（用于 RAG 搜索）
model ArticleVector {
  id            Int      @id @default(autoincrement())
  articleId     Int
  article       Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  contentChunk  String   // 文本块内容
  embedding     Bytes    // 向量数据 (BLOB)
  createdAt     DateTime @default(now())

  @@map("article_vectors")
}

// 分类模型
model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())

  articles Article[]

  @@map("categories")
}

// 标签模型
model Tag {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  articles Article[]

  @@map("tags")
}

// 评论模型
model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  status    CommentStatus @default(PENDING)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authorId Int?
  author   User?     @relation(fields: [authorId], references: [id], onDelete: SetNull)

  // 游客评论信息
  guestName  String?
  guestEmail String?
  guestUrl   String?

  // 文章关联（可以是数据库文章或 slug）
  articleId Int?
  article   Article?   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleSlug String?  // 用于 Astro 内容集合的文章 slug

  // 嵌套回复
  parentId Int?
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentReplies")

  // 通知关联
  notifications Notification[]

  @@unique([articleId, articleSlug]) // 确保每篇文章只有一个评论线程
  @@map("comments")
}

// 评论状态枚举
enum CommentStatus {
  PENDING
  APPROVED
  REJECTED
  SPAM
}

// 聊天会话模型
model ChatSession {
  id        Int      @id @default(autoincrement())
  sessionId String   @unique
  title     String?
  messages  Message[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("chat_sessions")
}

// 聊天消息模型
model Message {
  id         Int           @id @default(autoincrement())
  role       MessageRole
  content    String
  tokenCount Int?
  createdAt  DateTime      @default(now())

  sessionId  Int
  session    ChatSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("messages")
}

// 消息角色枚举
enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

// 通知模型
model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // 'comment_reply', 'comment_like', etc.
  content   String
  isRead    Boolean  @default(false)
  fromUserId Int?
  fromUser  User?    @relation("NotificationFromUser", fields: [fromUserId], references: [id], onDelete: SetNull)
  commentId Int?
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("notifications")
}

// 留言板模型
model Guestbook {
  id        Int      @id @default(autoincrement())
  nickname  String
  content   String
  userId    String?  // 可能是游客，留空或存用户ID
  createdAt DateTime @default(now())

  @@map("guestbook")
}
